# PyInstaller build output (~20 MB single-file exe + intermediates).
# The hand-written SignalCompanion.spec IS tracked; only generated output is ignored.
build/
dist/

# Python bytecode caches
__pycache__/
*.pyc
*.pyo

# Local diagnostic captures (kept out of the published repo)
dumps/

# MkDocs build output (docs source under docs/ + mkdocs.yml ARE tracked)
site/

# Inno Setup compiled installer (the .iss IS tracked; the built Setup.exe isn't)
installer/Output/
